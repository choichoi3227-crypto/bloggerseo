+// ── 공백 제외 글자수 계산 ────────────────────────────────────────────────
+function plainCharCount(html) {
+  const stripped = html.replace(/<[^>]+>/g, '');
+  const decoded = stripped
+    .replace(/&nbsp;/g, ' ')
+    .replace(/&amp;/g, '&')
+    .replace(/&lt;/g, '<')
+    .replace(/&gt;/g, '>')
+    .replace(/&quot;/g, '"');
+  const noSpace = decoded.replace(/[\s\u00A0\u3000]+/g, '');
+  return [...noSpace].length; // 유니코드 안전 카운트
+}
