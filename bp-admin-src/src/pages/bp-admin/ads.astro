---
import AdminLayout from '../../layouts/AdminLayout.astro';
import ShareButtonSettings from '../../components/ShareButtonSettings.tsx';
import ScrollPopupSettings from '../../components/ScrollPopupSettings.tsx';
---
<AdminLayout title="광고/공유" active="ads">
  <header class="page-head">
    <h1>광고/공유</h1>
    <p>SNS 공유 버튼과 스크롤 유도 팝업을 관리합니다. 부정 클릭 방지는 보안 메뉴에서 관리합니다.</p>
  </header>

  <div class="widgets-grid">
    <ShareButtonSettings client:load />
    <ScrollPopupSettings client:load />
  </div>

  <style>
    .page-head { margin-bottom: 24px; }
    .page-head h1 { font-size: 26px; margin-bottom: 6px; }
    .page-head p { margin: 0; color: var(--bp-text-mute); font-size: 14px; }
    .widgets-grid {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
  </style>
</AdminLayout>
