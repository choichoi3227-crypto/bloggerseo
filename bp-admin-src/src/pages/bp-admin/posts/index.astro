---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import PostList from '../../../components/PostList.tsx';
---
<AdminLayout title="글 관리" active="posts">
  <header class="page-head">
    <div>
      <h1>글 관리</h1>
      <p>Blogger에 직접 로그인하지 않고 여기서 글을 쓰고, 수정하고, 발행합니다.</p>
    </div>
    <a class="new-post-btn" href="/bp-admin/posts/new">새 글 작성</a>
  </header>

  <PostList client:load />

  <style>
    .page-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 24px;
    }
    .page-head h1 { font-size: 26px; margin-bottom: 6px; }
    .page-head p { margin: 0; color: var(--bp-text-mute); font-size: 14px; }
    .new-post-btn {
      flex-shrink: 0;
      background: var(--bp-accent);
      color: var(--bp-accent-ink);
      font-weight: 600;
      font-size: 14px;
      padding: 10px 18px;
      border-radius: var(--bp-radius-sm);
      text-decoration: none;
      white-space: nowrap;
    }
    .new-post-btn:hover { background: var(--bp-accent-hover); }
  </style>
</AdminLayout>
