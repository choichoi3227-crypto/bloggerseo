---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import PostEditor from '../../../components/PostEditor.tsx';
---
<AdminLayout title="새 글 작성" active="posts">
  <header class="page-head">
    <a class="back-link" href="/bp-admin/posts">← 글 목록</a>
    <h1>새 글 작성</h1>
  </header>

  <PostEditor client:load />

  <style>
    .page-head { margin-bottom: 20px; }
    .back-link {
      display: inline-block;
      margin-bottom: 8px;
      font-size: 13px;
      color: var(--bp-text-mute);
      text-decoration: none;
    }
    .back-link:hover { color: var(--bp-text); }
    .page-head h1 { font-size: 26px; }
  </style>
</AdminLayout>
